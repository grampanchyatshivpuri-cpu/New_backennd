# Environment Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database Configuration
# PostgreSQL connection string from Supabase
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Supabase Configuration
# Project URL from Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (NOT the anon key) from Supabase Dashboard > Settings > API > Project API keys
# This key has admin privileges and should be kept secure
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase Storage Bucket
SUPABASE_BUCKET_NAME=grampanchayat-files

# JWT Configuration
JWT_SECRET=your-generated-secret-here-use-256bit-key

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload Configuration
MAX_FILE_SIZE=10485760

# Admin Account (Auto-created on first run if not exists)
ADMIN_EMAIL=admin@grampanchayat.in
ADMIN_PASSWORD=strong-password-change-this
